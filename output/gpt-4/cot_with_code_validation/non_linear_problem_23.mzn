% Parameters
int: n; % Total number of currencies
int: m; % Number of involved currencies in the arbitrage loop
array[1..n, 1..n] of float: currencies; % Exchange rates between different currencies
array[1..n] of string: currencies_s; % Names of the currencies
float: start; % Initial amount in the base currency for trading

% Variables
array[1..m] of var 1..n: sequence; % Sequence of currencies in the arbitrage loop
var float: profit; % Total profit generated by the arbitrage loop

% Constraints
% The first and last currency in the sequence should be the same
constraint sequence[1] = sequence[m];

% The profit generated by the arbitrage loop should be positive
constraint profit > 0;

% The profit is calculated by multiplying the exchange rates of the currencies in the sequence
constraint profit = start * product(i in 2..m)(currencies[sequence[i-1], sequence[i]]) - start;

% Objective
% Maximize the total profit
solve maximize profit;