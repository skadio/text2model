% Parameters
int: n; % Total number of currencies
int: m; % Number of involved currencies in the arbitrage loop
array[1..n, 1..n] of float: currencies; % Exchange rates between different currencies
array[1..n] of string: currencies_s; % Names of the currencies
float: start; % Initial amount in the base currency for trading

% Variables
array[1..m] of var 1..n: sequence; % Sequence of currencies in the arbitrage loop
var float: profit; % Total profit generated by the arbitrage loop

% Constraints
constraint forall(i in 1..m-1)(currencies[sequence[i], sequence[i+1]] > 0); % There must be a valid exchange rate between each pair of consecutive currencies in the sequence
constraint currencies[sequence[m], sequence[1]] > 0; % There must be a valid exchange rate from the last currency in the sequence to the first one
constraint profit = start * product(i in 1..m)(currencies[sequence[i mod m + 1], sequence[i]]) - start; % The profit is the difference between the final amount and the initial amount

% Objective
solve maximize profit;