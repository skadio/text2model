# Sets
T = {1, ‚Ä¶, n}
P = {1, ‚Ä¶, m}
M = {1, ‚Ä¶, k}

# Parameters
d[t,p]          # demand
c[t,p]          # unit production cost
h[p]            # unit holding cost
a[t,p,m]        # machine‚ÄĎhour requirement
cap[t,m]        # machine capacity
I0[p]           # initial inventory
minProd[t,p]    # optional minimum production (0 if none)

# Variables
x[t,p] >= 0 integer   # production
I[t,p] >= 0 integer   # ending inventory

# Objective: maximise total profit
maximise
    sum_{t‚ąąT} sum_{p‚ąąP} ( (p_sell[p] - c[t,p]) * x[t,p] - h[p] * I[t,p] )

# Constraints
# 1. Production capacity
forall t‚ąąT, m‚ąąM:
    sum_{p‚ąąP} a[t,p,m] * x[t,p] <= cap[t,m]

# 2. Inventory balance
forall t‚ąąT, p‚ąąP:
    I[t,p] = I[t-1,p] + x[t,p] - d[t,p]
# initial inventory
forall p‚ąąP:
    I[0,p] = I0[p]

# 3. Non‚ÄĎnegativity (already in variable definition)

# 4. Minimum production (if required)
forall t‚ąąT, p‚ąąP:
    x[t,p] >= minProd[t,p]