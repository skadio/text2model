int: n = 8;
set of int: V = 1..n;

array[V] of float: x = [0.0, 0.0, 4.0, 8.0, 11.0, 11.0, 7.0, 1.0];
array[V] of float: y = [1.0, 6.0, 10.0, 10.0, 7.0, 4.0, 0.0, 0.0];

array[V] of float: a = [
  1.0,
  -0.7071067811865475,
  0.0,
  -0.7071067811865475,
  -1.0,
  0.7071067811865475,
  0.0,
  0.7071067811865475
];

array[V] of float: b = [
  0.0,
  0.7071067811865475,
  -1.0,
  -0.7071067811865475,
  0.0,
  0.7071067811865475,
  1.0,
  0.7071067811865475
];

array[V] of float: c = [
  0.0,
  4.242640687119285,
  -10.0,
  -1.414213562373095,
  -11.0,
  5.65685424949238,
  0.0,
  0.7071067811865475
];

var 0.0..11.0: cx;
var 0.0..10.0: cy;
var 0.0..100.0: r;

constraint forall(i in V) (a[i] * cx + b[i] * cy >= c[i] + r);

solve maximize r;

float: pi = 3.141592653589793;

output [
  "r = ", show_float(10, 6, r), "\n",
  "area = ", show_float(10, 6, pi * r * r), "\n"
];