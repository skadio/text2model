% Metal-working equipment purchasing (integer optimization)
% Data embedded as requested.

include "globals.mzn";

% Equipment characteristics (per day)
int: chop_capacity = 25;     % pounds of steel cut by one chop saw
int: chop_waste    = 25;     % waste units generated by one chop saw

int: cutter_capacity = 5;    % pounds of steel cut by one steel cutter
int: cutter_waste    = 3;    % waste units generated by one steel cutter

% Requirements / limits (per day)
int: demand = 520;           % pounds of steel to cut
int: waste_limit = 400;      % max waste units allowed

% Decision variables: number of each machine to purchase (nonnegative integers)
var 0..demand div min(chop_capacity, cutter_capacity) + 100: nChop;
var 0..demand div min(chop_capacity, cutter_capacity) + 100: nCutter;

% Constraints
constraint chop_capacity * nChop + cutter_capacity * nCutter >= demand;
constraint chop_waste * nChop + cutter_waste * nCutter <= waste_limit;

% Objective: minimize total equipment count
var int: totalMachines = nChop + nCutter;
solve minimize totalMachines;

output [
  "Chop saws = ", show(nChop), "\n",
  "Steel cutters = ", show(nCutter), "\n",
  "Total machines = ", show(totalMachines), "\n",
  "Total capacity = ", show(chop_capacity*nChop + cutter_capacity*nCutter), " lbs/day\n",
  "Total waste = ", show(chop_waste*nChop + cutter_waste*nCutter), " units/day\n"
];